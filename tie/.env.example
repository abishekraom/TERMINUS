# TIE Internal Config
PORT=3002
LOG_LEVEL=debug
NODE_ENV=development

# VDIE Webhook for A* Graph Updates
VDIE_WEBHOOK_URL=http://localhost:3001/internal/threat-update
INTERNAL_API_KEY=

# Gemini AI (Required)
GEMINI_API_KEY=your_gemini_api_key

# Firecrawl (Required for deep link scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Data Sources API Keys (Optional/Depending on Source)
NEWSAPI_KEY=your_newsapi_key
ACLED_API_KEY=your_acled_key
ACLED_EMAIL=your_acled_email
OWM_API_KEY=your_open_weather_map_key

# Firebase settings
FIREBASE_PROJECT_ID=terminus-dev
FIREBASE_CLIENT_EMAIL=admin@terminus-dev.iam.gserviceaccount.com
# Use literal \n characters for line breaks in the private key string below
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
